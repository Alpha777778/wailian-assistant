{
  "manifest_version": 3,
  "name": "外链助手 - SEMrush 博客评论提交",
  "version": "1.0.0",
  "description": "从 SEMrush 提取竞品外链，自动过滤博客评论机会并提交",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "*://*.semrush.com/*",
    "*://*.3ue.co/*",
    "*://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.semrush.com/analytics/backlinks/backlinks/*",
        "*://*.3ue.co/analytics/backlinks/backlinks/*"
      ],
      "js": ["content_semrush.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["xlsx.mini.min.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
